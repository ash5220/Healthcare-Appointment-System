# ── Docker Compose environment template ──────────────────────────
# Copy to .env.docker and fill in real values before running:
#   cp .env.docker.example .env.docker
#
# NEVER commit .env.docker — it contains secrets.

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (MySQL)
DB_DIALECT=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=healthcare_db
DB_USER=CHANGE_ME_db_user
DB_PASSWORD=CHANGE_ME_strong_random_password
# Path to AWS RDS CA bundle mounted into the container (see docker-compose.prod.yml volumes).
DB_SSL_CA_PATH=/etc/ssl/certs/aws-rds-global-bundle.pem

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_byte_hex_secret
JWT_REFRESH_EXPIRES_IN=7d

# MFA & Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_TOKEN_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret
ENCRYPTION_KEY=CHANGE_ME_generate_a_32_byte_hex_key

# Frontend (exact origin — no trailing slash)
# Production value: https://infinitesevens.com
FRONTEND_URL=http://localhost:4200

# Rate Limiting — defaults match backend/src/config/constants.ts
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_email@example.com
SMTP_PASSWORD=CHANGE_ME_email_password

# Logging
LOG_LEVEL=debug
