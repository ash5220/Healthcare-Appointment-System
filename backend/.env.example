# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (MySQL)
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=healthcare_db
DB_USER=root
DB_PASSWORD=your_password_here
# Path to AWS RDS CA bundle — required in production (Lightsail Managed MySQL).
# Download: curl -fsSL https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem -o ~/certs/aws-rds-global-bundle.pem
DB_SSL_CA_PATH=

# JWT — in production use strong random values (see README)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# MFA & session signing — dev fallback exists in code; set explicitly for clarity
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_TOKEN_SECRET=your-mfa-token-secret-change-in-production

# AES-256-GCM for sensitive fields at rest — dev fallback exists in code; set explicitly for clarity
# Production requires ≥32 characters (see validateProductionEnv)
ENCRYPTION_KEY=your-encryption-key-at-least-32-chars-long

# Frontend (exact origin, include scheme; no path or trailing slash)
# Production value: https://infinitesevens.com
FRONTEND_URL=http://localhost:4200

# Rate limiting — defaults match backend/src/config/constants.ts (500 req / 15 min window by default)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Redis — loaded by env.ts for future use (current API rate limiting uses MySQL or in-memory store)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (SendGrid Web API — https://app.sendgrid.com/settings/api_keys)
# EMAIL_FROM must be a verified sender in your SendGrid account
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=your-verified-sender@example.com

# Logging
LOG_LEVEL=debug
